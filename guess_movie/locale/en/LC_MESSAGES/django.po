#: quizz/templates/quizz/home.html:23
msgid "home-principle"
msgstr ""
"<p>Guess <span class='imp-word'>the movie</span> from which <span class='imp-"
"word'>a quote</span> or <span class='imp-word'>screenshots</span> are taken</"
"p><p>But be careful, everything is <span class='imp-word'>random</span>! "
"Don't expect to get only the most famous quotes/screenshots. It is the "
"global knowledge of the movies that will allow you to win!</p><p>In "
"Screenshot mode, <span class='imp-word'>the faster you are</span>, <span "
"class='imp-word'>the more points you will score</span>!</p>"

#: quizz/templates/quizz/home.html:28
msgid "How to play?"
msgstr ""

#: quizz/templates/quizz/home.html:30
msgid "home-how"
msgstr ""
"<p>Create a room and play <span class='imp-word'>solo</span> or <span "
"class='imp-word'>with your friends</span> by sharing the link.</p><p>Are you "
"a fan of 80's science fiction or spaghetti westerns? Customize the list of "
"movies by <span class='imp-word'>genre and year</span>. If too many movies "
"seem unfamiliar to you, you can even <span class='imp-word'>filter by "
"popularity</span> to take it easy.</p>"

